# ============================================
# Optisafe.fr — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# ============================================

# --- Application ---
APP_DOMAIN=optisafe.alsek.fr
NEXT_PUBLIC_APP_URL=https://optisafe.alsek.fr
NODE_ENV=production

# --- Base de données (PostgreSQL) ---
POSTGRES_DB=optisafe
POSTGRES_USER=optisafe
POSTGRES_PASSWORD=CHANGEZ_MOI
DATABASE_URL=postgresql://optisafe:CHANGEZ_MOI@db:5432/optisafe?schema=public

# --- Redis (BullMQ) ---
REDIS_URL=redis://redis:6379

# --- Authentification (JWT) ---
# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_DE_64_CHARS

# --- Google AI (Gemini) ---
GEMINI_API_KEY=VOTRE_CLE_API_GEMINI

# --- Stockage des fichiers contrats ---
CONTRACTS_UPLOAD_DIR=/data/contracts

# --- Optionnel : limites ---
MAX_FILE_SIZE_MB=20
MAX_CONTRACTS_PER_USER=50
